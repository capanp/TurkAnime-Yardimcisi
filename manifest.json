{
    "manifest_version": 3,
    "name": "TürkAnime Yardımcısı",
    "description": "Türk anime izleme platformlarını geliştiren bir tarayıcı eklentisi.",
    "version": "4.2",
    "icons": {
        "16":"/icons/16px.png",
        "48":"/icons/48px.png",
        "128":"/icons/128px.png"
    },
    "action": {
      "default_popup": "index.html",
      "default_icon": {
        "16":"/icons/16px.png",
        "48":"/icons/48px.png",
        "128":"/icons/128px.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.turkanime.com/*",
                "https://*.turkanime.co/*",
                "https://*.turkanime.net/*",
                "https://*.turkanime.org/*",
                "https://*.turkanime.tv/*",
                "https://*.tranimeizle.io/*",
                "https://*.anizm.net/*",
                "https://*.animecix.tv/*",
                "https://asyaanimeleri.top/*",
                "https://openani.me/*"
            ],
            "css": ["./css/trahelper.css"],
			"js": ["./js/inject.js"]
        }
    ],
    "permissions": [
        "storage"
    ]
}
