{
    "manifest_version": 3,
    "name": "TürkAnime Yardımcısı (turkanime.co)",
    "description": "Türk anime izleme platformlarını geliştiren bir tarayıcı eklentisi.",
    "version": "1.1",
    "icons": {
        "16":"/icons/16px.png",
        "48":"/icons/48px.png",
        "128":"/icons/128px.png"
    },
    "action": {
      "default_popup": "index.html",
      "default_icon": {
        "16":"/icons/16px.png",
        "48":"/icons/48px.png",
        "128":"/icons/128px.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.turkanime.com/*",
                "https://www.turkanime.co/*",
                "https://www.turkanime.net/*",
                "https://www.turkanime.org/*",
                "https://www.turkanime.tv/*"
            ],
            "css": ["./css/main.css"],
			"js": ["./js/inject.js"]
        }
    ],
    "permissions": [
        "storage"
    ]
}